auto-install-peers=true

# Shared pnpm store path: same on host and inside the workmux sandbox.
# Path-identity matters because pnpm writes absolute paths into store
# metadata and node_modules symlink targets — without a shared path,
# host pnpm and sandbox pnpm would treat each other's store as alien.
# The global workmux config bind-mounts /tmp/pnpm-store into the sandbox
# at the same absolute path (see ~/.config/workmux/config.yaml).
# Using a literal /tmp path keeps the value free of any $USER reference,
# so the same .npmrc works for every teammate.
store-dir=/tmp/pnpm-store
